# ============================================================
# AgenticMail Environment Configuration
# Copy this file to .env and update the values
# ============================================================

# --- Stalwart Mail Server ---
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=changeme
STALWART_URL=http://localhost:8080

# --- AgenticMail Core ---
# Master key for admin API access (generate with: openssl rand -hex 32)
AGENTICMAIL_MASTER_KEY=mk_changeme
AGENTICMAIL_API_PORT=3100
AGENTICMAIL_DATA_DIR=~/.agenticmail

# --- SMTP/IMAP (local Stalwart) ---
SMTP_HOST=localhost
SMTP_PORT=587
IMAP_HOST=localhost
IMAP_PORT=143

# --- Gateway: Relay Mode (Gmail/Outlook) ---
# Uncomment to use relay mode
# RELAY_PROVIDER=gmail
# RELAY_EMAIL=you@gmail.com
# RELAY_PASSWORD=xxxx xxxx xxxx xxxx

# --- Gateway: Domain Mode (Cloudflare) ---
# Uncomment to use domain mode
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# AGENTICMAIL_DOMAIN=yourdomain.com

# --- Inbound Webhook (Cloudflare Email Worker) ---
# Secret shared between the Email Worker and the inbound endpoint
# Auto-generated during domain setup if not set
# AGENTICMAIL_INBOUND_SECRET=your_inbound_secret

# --- Gmail SMTP Relay (for domain mode outbound) ---
# Recommended if your IP lacks a PTR record (residential connections)
# GMAIL_RELAY_EMAIL=you@gmail.com
# GMAIL_RELAY_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Realtime Voice ---
# OpenAI API key used only by the realtime voice bridge to open an
# OpenAI Realtime (gpt-realtime) session for live phone calls. When
# unset, phone missions still place and track calls (call-control),
# but a carrier realtime-media stream cannot be bridged to a model.
# Optional — no other feature depends on it.
# OPENAI_API_KEY=sk-your_openai_api_key

# --- Phone Transport (call-control + realtime voice) ---
# AgenticMail places outbound calls through one of two carriers. Pick a
# provider, then fill in that provider's credentials. Per-agent phone
# transport config is normally set with `agenticmail setup` (interactive)
# or the phone_transport_setup tool — these vars are for reference.
#
# Public HTTPS base URL the carrier reaches AgenticMail webhooks on:
# PHONE_WEBHOOK_BASE_URL=https://your-public-host.example.com
# Shared secret for phone webhook tokens (at least 24 characters):
# PHONE_WEBHOOK_SECRET=your_phone_webhook_secret
#
# Provider A — 46elks:
# ELKS_API_USERNAME=your_46elks_api_username
# ELKS_API_PASSWORD=your_46elks_api_password
#
# Provider B — Twilio:
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token

# --- Telegram Channel ---
# A Telegram bot the agent uses as a chat channel. Get a bot token from
# @BotFather, then link the chat id(s) allowed to message the agent.
# Per-agent Telegram config is normally set with `agenticmail setup`
# (interactive) or the telegram_setup tool — these vars are for reference.
# TELEGRAM_BOT_TOKEN=123456789:your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Debug ---
# Set to any value to enable verbose per-message logging
# (relay poll processing, inbound delivery, SMTP send confirmations)
# AGENTICMAIL_DEBUG=1
